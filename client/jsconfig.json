{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@components/*": [
                "./src/components/*"
            ],
            "@lib/*": [
                "./src/lib/*"
            ],
            "@pages/*": [
                "./src/pages/*"
            ],
            "@hooks/*": [
                "./src/hooks/*"
            ],
            "@contexts/*": [
                "./src/contexts/*"
            ],
            "@services/*": [
                "./src/services/*"
            ]
        }
    },
    "include": [
        "src"
    ]
}